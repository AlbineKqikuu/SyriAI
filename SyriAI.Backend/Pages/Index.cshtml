@page
@model IndexModel
@{
    ViewData["Title"] = "SyriAI - Premium Broadcast Suite";
}

@if (User.Identity.IsAuthenticated)
{
    <script>
        window.location.href = "/studio/AdminPage.html";
    </script>
    <div class="d-flex flex-column align-items-center justify-content-center min-vh-75 text-center">
        <div class="spinner-border text-primary mb-4" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Loading...</span>
        </div>
        <h2 class="text-white fw-bold">Duke hapur Studion...</h2>
        <p class="text-muted">Ridrejtimi automatik po kryhet. Nëse nuk ndodh, <a href="/studio/AdminPage.html" class="text-primary">klikoni këtu</a>.</p>
    </div>
}
else
{
    <div class="hero-section d-flex align-items-center justify-content-center">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8 text-center">
                    <div class="brand-badge mb-4">SYRIAI BROADCAST</div>
                    <h1 class="hero-title mb-4">
                        Fuqizoni Transmetimin tuaj me <span class="gradient-text">Inteligjencë Artificiale</span>
                    </h1>
                    <p class="hero-subtitle mb-5">
                        Platforma profesionale për teleprompter, analitikë të shikimit dhe efekte në kohë reale. 
                        Kyçuni në studio për të nisur prodhimin tuaj të ardhshëm.
                    </p>
                    
                    <div class="cta-wrapper d-flex flex-column flex-sm-row gap-4 justify-content-center">
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg cta-btn shadow-glow">
                            <span class="btn-text">KYÇU (LOGIN)</span>
                            <span class="btn-icon">→</span>
                        </a>
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-light btn-lg cta-btn">
                            KRIJO LLOGARI
                        </a>
                    </div>

                    <div class="features-preview mt-5 pt-4">
                        <div class="row g-4">
                            <div class="col-4">
                                <div class="f-item">
                                    <span class="f-icon">👁️</span>
                                    <span class="f-label">Gaze Tracking</span>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="f-item">
                                    <span class="f-icon">⏳</span>
                                    <span class="f-label">Real-time Analytics</span>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="f-item">
                                    <span class="f-icon">🎬</span>
                                    <span class="f-label">Studio Effects</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .hero-section {
        min-height: 80vh;
        position: relative;
        overflow: hidden;
    }

    .brand-badge {
        display: inline-block;
        padding: 0.5rem 1rem;
        background: rgba(245, 158, 11, 0.1);
        border: 1px solid rgba(245, 158, 11, 0.3);
        border-radius: 50px;
        color: var(--primary);
        font-weight: 700;
        font-size: 0.75rem;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .hero-title {
        font-size: 4rem;
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: -2px;
        color: #fff;
    }

    .gradient-text {
        background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .hero-subtitle {
        font-size: 1.25rem;
        color: var(--text-muted);
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }

    .cta-btn {
        padding: 1.2rem 2.5rem !important;
        font-size: 1.1rem !important;
        border-radius: 16px !important;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .shadow-glow {
        box-shadow: 0 0 20px rgba(245, 158, 11, 0.3);
    }

    .btn-icon {
        transition: transform 0.3s ease;
    }

    .cta-btn:hover .btn-icon {
        transform: translateX(5px);
    }

    .f-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

    .f-icon {
        font-size: 1.5rem;
    }

    .f-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    @@media (max-width: 768px) {
        .hero-title {
            font-size: 2.5rem;
        }
    }
</style>
